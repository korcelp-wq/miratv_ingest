# MiraTV Ingest .gitignore (tight governance scope)

# Secrets and credentials
*.env
*.env.*
secrets*/
*.key
*.pem
*.crt
*.pfx
*.jks
*.keystore
*.p12
*token*
*secret*
*password*
*credential*
*.bak

# Provider/API config with secrets
provider_config.json
api_keys.json
config/api_*.json
config/provider_*.json

# Logs and runtime status
*.log
logs/
log/
*.out
*.err
*.pid
status/
run/
*.sqlite
*.db

# Raw ingest payloads
raw/
processed/
epg.xml
series_latest.json
vod_*.json
live_*.json
*.m3u
*.xmltv
*.xml.gz
*.jsonl
*.csv.gz

# Reports, output, temp
reports/
output/
tmp/
temp/
*.tmp
*.swp
*.swo
*.bak
*.old
*.off

# Backups, old/off/copy files
backup/
backups/
old/
off/
copy/
*.copy
*.old
*.off
*.bak

# IDE/Editor/Build artifacts
.idea/
.vscode/
.DS_Store
Thumbs.db
*.iml
.gradle/

node_modules/
__pycache__/
*.pyc
*.class
*.apk
*.ap_
runtime/
runtime/
runtime/
